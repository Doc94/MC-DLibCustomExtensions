{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "automerge": true,
  "packageRules": [
    {
      "matchCurrentValue": "/-SNAPSHOT$/",
      "enabled": false
    },
    {
      "matchPackageNames": ["io.papermc.paper:paper-api", "paper"],
      "automerge": false
    }
  ]
}
